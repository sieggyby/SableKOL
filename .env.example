# ============================================================
# SableKOL — Environment Variables
# Copy to .env (or set in your shell / sidecar compose env).
# ============================================================

# ---------------------------------------------------------------------------
# CLI usage (existing surface — bank ETL, find, regenerate)
# ---------------------------------------------------------------------------

# Anthropic key for Haiku classification + match rationales. Falls back to
# ~/.sable/config.yaml `anthropic_api_key`.
# ANTHROPIC_API_KEY=

# SocialData key for --paid-enrich and bulk-fetch followers/following. Falls
# back to ~/.sable/config.yaml `socialdata_api_key`.
# SOCIALDATA_API_KEY=

# sable.db location. Same convention as SablePlatform / SableWeb.
# SABLE_DATABASE_URL=postgresql://sable:password@localhost:5432/sable
# SABLE_DB_PATH=~/.sable/sable.db

# ---------------------------------------------------------------------------
# Preflight sidecar (Phase B — any-project KOL wizard)
# These are read by sable_kol/preflight_service.py and sable_kol/grok_api.py.
# Set them in the sidecar container's environment via SableWeb's compose,
# NOT in SableWeb's environment block. xAI key never reaches the Node bundle.
# ---------------------------------------------------------------------------

# xAI Grok API key. REQUIRED — the sidecar hard-fails on missing key.
# Generate at https://x.ai (xAI dashboard).
XAI_API_KEY=

# Shared token between SableWeb and the preflight sidecar. REQUIRED —
# both ends hard-fail on missing token.
# Generate with: openssl rand -hex 32
# Rotate every 90 days.
SABLE_SERVICE_TOKEN=

# Sidecar's URL as seen from SableWeb (compose-network hostname). Set on
# SableWeb's web container, not the sidecar itself.
# SABLE_KOL_SERVICE_URL=http://sable-kol-preflight:8001
